{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://letterblack.local/contracts/endpoint.schema.json",
  "title": "Custom Endpoint",
  "type": "object",
  "required": [
    "id",
    "name",
    "baseUrl"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "baseUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "healthCheck": {
      "type": "object"
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}