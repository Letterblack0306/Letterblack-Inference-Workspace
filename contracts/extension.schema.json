{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://letterblack.local/contracts/extension.schema.json",
  "title": "Declarative Extension Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "apiVersion",
    "permissions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "apiVersion": {
      "const": "1"
    },
    "description": {
      "type": "string"
    },
    "compatibility": {
      "type": "object"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "action.schema.json"
      }
    },
    "endpoints": {
      "type": "array",
      "items": {
        "$ref": "endpoint.schema.json"
      }
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}