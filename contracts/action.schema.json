{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://letterblack.local/contracts/action.schema.json",
  "title": "Custom Action",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "permissions",
    "config"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "enum": [
        "http-request",
        "controller-status",
        "rpc-start",
        "rpc-stop",
        "models-scan",
        "profile-select"
      ]
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "config": {
      "type": "object"
    },
    "confirmation": {
      "enum": [
        "always",
        "dangerous-only",
        "never"
      ]
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}