{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://letterblack.local/schemas/machine.schema.json",
  "title": "Machine",
  "type": "object",
  "required": ["id", "name", "addresses", "controller", "rpc"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"},
    "name": {"type": "string", "minLength": 1},
    "addresses": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "controller": {"type": "object", "required": ["scheme", "port"], "properties": {"scheme": {"enum": ["http", "https"]}, "port": {"type": "integer", "minimum": 1, "maximum": 65535}}},
    "rpc": {"type": "object", "required": ["port", "enabled"], "properties": {"port": {"type": "integer", "minimum": 1, "maximum": 65535}, "enabled": {"type": "boolean"}}},
    "paths": {"type": "object", "additionalProperties": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "enabled": {"type": "boolean"}
  },
  "additionalProperties": true
}
